	{
		if(array_contains(_attack.hit_list, self))
		{
			//do nothing
			//already hit
		}
		else{
			//take damage
			hp-= _attack.attack;
			//add to hit list
			array_push(_attack.hit_list, self);
			//add score to total
			//score += point_value;
		}
	}
}

