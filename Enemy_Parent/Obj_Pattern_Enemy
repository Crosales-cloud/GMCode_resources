	DEAD: 0,
	ACTIVE: 1,

}
state = states.ACTIVE

function get_hit(_attack = noone)
{
	if(_attack != noone && state != states.DEAD)
	{
		if(array_contains(_attack.hit_list, self))
		{
			//do nothing
			//already hit
		}
		else{
			//take damage
			hp -= _attack.attack;
			//add to hit list
			array_push(_attack.hit_list, self);
		}
	}
}

