//Caesar alphabet for the Saucy Crusaders
var ALPHABET = ["W","1","N","@","n","h","B"," ","Y","A","!","r","_","F","y","R","7","c","T","4","V","X","G","H","K","$","=","6","Q","0","C",",","+","E","?","t","L","J","e","v","f","i","u","j","g","q","8","s","z","b","D","o","3","#","a","O","k","5","S","P","M","9","w","$","I","d","x","l","2",".","m","p","-","Z","U"];

//encoded message (should decode when the user inputs a key value of "J")
var MESSAGE = "qFng6@6g@-2goFngrn@0-g7gaF6Wgaz7aT@iBgEzFBz7+,gcig-Fg5@a-FzogNFzg-uWgV7naoglznA76WzAs";


onEvent("btn_encode", "click", function() {
  setText("text_input", getText("text_input"));
  encode();
});
onEvent("btn_decode", "click", function() {
  setText("text_input",getText("text_input"));
  decode();
});
function encode() {
    var rawKey = getText("shift_input");
    var shift = validateKeyAndReport(rawKey);
    if (shift === -1) return;
    var msg = getText("text_input");
    var result = transform(msg, shift);
    setText("text_output", result);
}
function decode() {
    var rawKey = getText("shift_input");
    var shift = validateKeyAndReport(rawKey);
    if (shift === -1) return;
    var msg = getText("text_input");
    var result = transform(msg, -shift);
    setText("text_output", result);
}

function validateKeyAndReport(rawKey) {
  if (!rawKey || rawKey.length === 0) {
    setText("statusLabel", "Enter a key character (last char used).");
    return -1;
  }
  var s = keyToShift(rawKey);
  if (s === -1) {
    setText("statusLabel", "Key invalid — character not in alphabet.");
    return -1;
  }
  setText("statusLabel", "Using key '" + rawKey.charAt(rawKey.length - 1) + "' → shift " + s + ".");
  return s;
}

// Transform text by shift (positive to encode, negative to decode)
// Uses loops, arrays, and string operations only
function transform(text, shift) {
  var L = ALPHABET.length;
  // normalize shift
  shift = ((shift % L) + L) % L;
  var Temp = [];
  for (var t = 0; t < text.length; t++) {
    var ch = text.charAt(t);
    var idx = -1;
    for (var a = 0; a < ALPHABET.length; a++) {
      if (ALPHABET[a] === ch) { idx = a; break; }
    }
    if (idx === -1) {
      Temp.push(ch);
    } else {
      var newIdx = (idx + shift) % L;
      Temp.push(ALPHABET[newIdx]);
    }
  }
  // join without using array.join() is allowed; using join() is string/array method acceptable
  return (Temp.join(""));
}

function keyToShift(key) {
  if (!key || key.length === 0) return -1;
  var ch = key.charAt(key.length - 1);
  for (var i = 0; i < ALPHABET.length; i++) {
    if (ALPHABET[i] === ch) return i;
  }
  return -1;
}
