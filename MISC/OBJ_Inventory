STATES = {
	OFF: 0,
	ON: 1,
}
state = STATES.OFF

function state_toggle()
{
	state++;
	if(state > STATES.ON)
	{
		state = STATES.OFF;
	}
}

weapon_list = {
	MELEE : ITEM_TYPES.SWORD,
	MELEE_UPGRADE : ITEM_TYPES.SWORD,
	FIRE: ITEM_TYPES.FIRE,
	FIRE_SPREAD: ITEM_TYPES.SPREAD,
	HOMING: ITEM_TYPES.HOMING,
	BOOMERANG: ITEM_TYPES.BOOMERANG,
	BOMB: ITEM_TYPES.BOMB,
};

//weapon pickup
function player_weapon_select(_obj = obj_inventory)
{
	var _success = false;
	_obj = inventory_search(_obj,inventory[inv_index][ITEM_DATA.TYPE]);
	if (_obj != noone)
	{
		switch(_obj.object_index)
		{
			case weapon_list.MELEE:
			weapon_a = obj_melee;
			_success = true;
			break;
			case weapon_list.MELEE_UPGRADE:
			weapon_a = obj_melee;
			_success = true;
			break;
			case weapon_list.FIRE:
			weapon_b = obj_fire;
			_success = true;
			break;
			case weapon_list.FIRE_SPREAD:
			weapon_b = obj_spread_fire;
			_success = true;
			break;
			case weapon_list.HOMING:
			weapon_b = obj_homing_attack;
			_success = true;
			break;
			case weapon_list.BOOMERANG:
			weapon_b = obj_boomerang_attack;
			_success = true;
			break;
			case weapon_list.BOMB:
			weapon_b = Obj_Bomb_Attack;
			_success = true;
			break;
		}
	}
	return _success;
}

