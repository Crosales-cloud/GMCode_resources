//Create Event 
//is game paused?
global.paused = false;

//refer to drawing surface
//use this in case it gets changed
pause_surface = -1;

//refer to drawing surface buffer
pause_surface_buffer = -1;

//set default resolution info
//we are using the post draw event, so always x,y begins at 0,0
_x = 0;
_y = 0;
_width = 1920;
_height = 1080;
//set camera resolution info
if(view_visible[0])
{
	_width = global.camera[0].width;
	_height = global.camera[0].height;
}


//Step Event 


//draw "frozen" pause surface
//do first so no frame glithcing when unpausing
if(global.paused)
{
	//alpha blending of sprites slows things down, disable this bc alpha isnt needed for surface with no alpha
	gpu_set_blendenable(false);
	
	//target application surface
	surface_set_target(application_surface);
	
	//draw surface if exists, reset to buffer if not
	if( surface_exists(pause_surface) )
	{
		draw_surface(pause_surface, _x, _y);
	}
	else
	{
		pause_surface = surface_create(_width, _height);
		buffer_set_surface(pause_surface_buffer, pause_surface, 0);
	}
	//resset target surface
	surface_reset_target();
	
	//re-enable if disabled above
	gpu_set_blendenable(true);
}


//what to do when pause buttone is pressed
if(keyboard_check_pressed(vk_escape))
{
	//set pause to its opp
	global.paused = !global.paused;
	
	//did we pause or unpause
	//WHAT TO DO WHEN WE INITIALLY PAUSE
	if(global.paused)
	{
		//only happens once
		//deactivate objects you need
		instance_deactivate_all(true);
	
		//potential extra things
		instance_activate_layer("controllers");
	
		//create new surface
		pause_surface = surface_create(_width, _height);
		//set new surface as drawing
		surface_set_target(pause_surface);
		draw_surface(application_surface, 0, 0);
	
		//draw extra pause menu
		draw_set_alpha(0.5);
		draw_rectangle_color(_x, _y, _x + _width, _y + _height, c_black, c_black, c_black, c_black, false);
		draw_set_halign(fa_center);
		draw_set_color(c_aqua);
		draw_set_font(font_pause)
		draw_set_alpha(1);
		var _i = -1;
		var _line = 36;
		draw_text(_x + (_width / 2), (_y + (_height / 2)) + (_i++ * _line), "GAME is PAUSED");
		draw_text(_x + (_width / 2), (_y + (_height / 2)) + (_i++ * _line), "Press <ESC> to RESUME");
	
		//reset the target drawing surface back to wtv its supposed to be
		surface_reset_target();
		//make backup in case surface gets deleted 
		//delete if alr exists
		if(buffer_exists(pause_surface_buffer))
		{
			buffer_delete(pause_surface_buffer);
		}
		//create new empty buffer
		pause_surface_buffer = buffer_create(_width * _height * 4, buffer_fixed, 1);
		//put surface into buffer
		buffer_get_surface(pause_surface_buffer, pause_surface, 0);
	}
	else
	{
		//not paused, only happens once
		//reactivate what we need
		instance_activate_layer("controllers");
		instance_activate_layer("HUD");
		instance_activate_layer("UI");
		instance_activate_layer("player");
		//camera can reactivate enemies/terrain
		if( instance_exists(obj_camera_adv))
		{
			obj_camera_adv.camera_activate_within();
		}
	
		//clear surface from memory
		if(surface_exists(pause_surface))
		{
			surface_free(pause_surface);
		}
	
		//clear buffer from memory
		if(buffer_exists(pause_surface_buffer))
		{
			buffer_delete(pause_surface_buffer);
		}
	}
}


